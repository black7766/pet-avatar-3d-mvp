.env
__pycache__/
*.pyc
*.pyo
.pytest_cache/

# Large/generated intermediates. Final demo assets already copied are kept.
poc_output/**/frames_*/
poc_output/**/raw_*.mp4
poc_output/**/raw_*.mov
poc_output/**/raw_*.webm
poc_output/**/state_*_raw.jpeg
poc_output/**/candidates/
poc_output/**/*.download
poc_output/**/*.tmp
poc_output/*verify*.png
legacy_webp_mvp/**/__pycache__/
legacy_webp_mvp/assets/**/frame_*.png
legacy_webp_mvp/assets/compare/*/frame_*.png
legacy_webp_mvp/assets/native/*/frame_*.png

# Local runtime scratch.
artifacts/
tmp/
logs/
poc_output/server_*.log
poc_output/_ab_*/
poc_output/_inspect_*/

# Local matting model lab. Keep adapters and reports, ignore heavy runtimes/assets.
.models/
.venvs/
matting_bench/data/
matting_bench/outputs/
matting_bench/providers/*/outputs/
matting_bench/providers/*/samples/
matting_bench/providers/*/upstream/
matting_bench/providers/*/evidence/
matting_bench/providers/*/runs/
matting_bench/providers/*/diagnostics/
matting_bench/providers/*/run_metrics/
matting_bench/providers/*/sample_inputs/
matting_bench/providers/*/sample_outputs/
matting_bench/providers/*/visual_review/
matting_bench/providers/*/*.log
poc_output/matting_benchmark_assets/
poc_output/matting_benchmark_*.html
poc_output/matting_tuning_report_*.html
poc_output/matting_tuning_report_*_assets/
